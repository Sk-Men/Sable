{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/sw.ts", "scripts/normalize-imports.js"],
  "ignoreExportsUsedInFile": {
    "interface": true,
    "type": true
  },
  "ignoreDependencies": ["buffer", "@element-hq/element-call-embedded", "workbox-precaching"],
  "rules": {
    "exports": "off",
    "types": "off",
    "enumMembers": "off"
  },
  "tags": ["-lintignore"]
}
